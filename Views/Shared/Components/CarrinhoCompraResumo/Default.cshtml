@model CarrinhoCompraViewModel

@if(Model.CarrinhoCompra.CarrinhoCompraItens.Count > 0)
{
    <a asp-controller="CarrinhoCompra" asp-action="Index">
        <span><img src="~/images/whitecart_icon.png" class="img-fluid" style="width:20px; height:20px;"/></span>
        <span style="color:white">
            @Model.CarrinhoCompra.CarrinhoCompraItens.Count
        </span>
    </a>
}